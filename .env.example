# Copy to .env.local and fill in. Never commit real keys.

# Server-side only. Used by app/api/ask/route.ts to call the Anthropic
# Messages API for the floating chat assistant. Never exposed to the client.
ANTHROPIC_API_KEY=

# Optional: model for the assistant (defaults to a current Claude model).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Contact form delivery (app/api/contact/route.ts). Uses Resend if set.
RESEND_API_KEY=
# Where contact submissions are delivered, and the verified "from" sender.
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Analytics (app/api/track/route.ts). If set, enriched events are POSTed here
# (send them to your database, a spreadsheet webhook, Tinybird, etc.). If unset,
# events are logged as structured JSON to your hosting provider's logs.
ANALYTICS_WEBHOOK_URL=
# Salt for the one-way visitor hash (unique-visitor counts without raw IPs).
ANALYTICS_IP_SALT=
# Set to 1 to turn off client-side analytics entirely.
NEXT_PUBLIC_ANALYTICS_DISABLED=
