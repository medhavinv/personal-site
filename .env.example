# Copy to .env.local and fill in. Never commit real keys.

# Server-side only. Used by app/api/ask/route.ts to call the Anthropic
# Messages API for the floating chat assistant. Never exposed to the client.
ANTHROPIC_API_KEY=

# Optional: model for the assistant (defaults to a current Claude model).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Contact form delivery (app/api/contact/route.ts). Uses Resend if set.
RESEND_API_KEY=
# Where contact submissions are delivered, and the verified "from" sender.
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Analytics store (Vercel KV / Upstash Redis) powers the /admin dashboard that
# ranks which sections hold attention. Add the Vercel Upstash (Redis)
# Marketplace integration (it injects KV_REST_API_URL / KV_REST_API_TOKEN), or
# set these directly. Without them, events still log server-side.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Protects /admin with HTTP Basic Auth. Admin is disabled until ADMIN_PASSWORD
# is set. ADMIN_USER defaults to "admin".
ADMIN_USER=admin
ADMIN_PASSWORD=

# Optional: also POST every enriched event to your own endpoint (DB, sheet).
ANALYTICS_WEBHOOK_URL=
# Salt for the one-way visitor hash (unique-visitor counts without raw IPs).
ANALYTICS_IP_SALT=
# Set to 1 to turn off client-side analytics entirely.
NEXT_PUBLIC_ANALYTICS_DISABLED=
